{
  "name": "divini-procure-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Divini Procure backend — Express + pg + Authentik OIDC (jose). Serves the API and the built SPA from one Node process.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsc -p tsconfig.json && node --enable-source-maps dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/morgan": "^1.9.10",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.3.0",
    "jose": "^5.9.6",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.5.4"
  }
}
